# ── Turso (base de données SQLite cloud) ──────────────────
# Créer un compte gratuit sur https://turso.tech
# puis : turso db create nom-de-votre-appart
#        turso db tokens create nom-de-votre-appart
TURSO_DATABASE_URL=libsql://votre-db.turso.io
TURSO_AUTH_TOKEN=votre-token-turso

# ── Cloudinary (stockage images) ───────────────────────────
# Créer un compte gratuit sur https://cloudinary.com
# Trouver ces valeurs dans : Dashboard > Account Details
CLOUDINARY_CLOUD_NAME=votre-cloud-name
CLOUDINARY_API_KEY=votre-api-key
CLOUDINARY_API_SECRET=votre-api-secret

# ── Sécurité ───────────────────────────────────────────────
JWT_SECRET=changez-moi-par-une-chaine-aleatoire-longue
JWT_EXPIRES_IN=24h

# ── Dev local uniquement ───────────────────────────────────
PORT=3000
